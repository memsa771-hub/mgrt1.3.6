# Node/Bun (match at any depth — Overlord-Server/node_modules etc.)
**/node_modules/
**/.next/
**/.cache/
**/dist/
**/.tmp/

# Database
**/*.db
**/*.db-journal

# Configuration (contains secrets)
**/config.json

# Certificates
**/certs/
**/*.crt
**/*.key
**/*.pem
**/*.csr

# Runtime data / uploads / plugins (mounted as volumes at runtime)
Overlord-Server/data/
Overlord-Server/uploads/
Overlord-Server/plugins/
plugins/

# OS
.DS_Store
Thumbs.db
.idea
.vscode

# Git
.git
.gitignore
.gitattributes

# Build outputs (dist-clients is provided by the builder stage in the runtime image)
**/dist-clients/
Overlord-Client/build/
release/

# Local docker buildx cache (host-only)
.docker-cache/

**/*.tsbuildinfo
**/coverage/
**/tmp/
**/temp/

# Logs
**/*.log
**/logs/
